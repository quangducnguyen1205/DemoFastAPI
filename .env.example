## FastAPI/Backend configuration

# PostgreSQL connection string
# Example for local Docker Compose (service name `db`):
# postgresql://<user>:<password>@db:5432/<database>
DATABASE_URL=postgresql://postgres:postgres@db:5432/userdb

# Root directory for uploaded media when running the app directly on the host.
# Docker Compose sets the in-container canonical path explicitly to /backend/media.
MEDIA_ROOT=media

# Conservative worker defaults for the processing worker
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Kafka consumer. The broker is expected to be provided by the product/Spring stack.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ASSET_PROCESSING_TOPIC=asset.processing.requested.v1
KAFKA_PROCESSING_RESULT_TOPIC=asset.processing.result.v1
KAFKA_CONSUMER_GROUP=fastapi-processing-v1
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_RECONNECT_BACKOFF_SECONDS=5
KAFKA_SEND_TIMEOUT_SECONDS=10

# Manual processing result outbox relay. Disabled by default and unscheduled.
PROCESSING_RESULT_PUBLISHER_ENABLED=false
PROCESSING_OUTBOX_RELAY_ENABLED=false
PROCESSING_OUTBOX_RELAY_BATCH_SIZE=10
PROCESSING_OUTBOX_RELAY_MAX_ATTEMPTS=5
PROCESSING_OUTBOX_RELAY_RETRY_DELAY_SECONDS=60

# Optional long-running processing result relay. It still requires starting the dedicated
# result-relay process/service explicitly and enabling PROCESSING_RESULT_PUBLISHER_ENABLED.
PROCESSING_OUTBOX_AUTO_RELAY_ENABLED=false
PROCESSING_OUTBOX_AUTO_RELAY_INTERVAL_SECONDS=10
PROCESSING_OUTBOX_AUTO_RELAY_BATCH_SIZE=10

# S3-compatible object storage used by the Celery worker to read Spring-owned media bytes.
OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1

# Optional Project3 cross-compose integration overlay.
# Used only with: docker compose -f docker-compose.yml -f docker-compose.project3.yml ...
# Base host/local defaults above remain unchanged for standalone use.
SPRING_INFRA_NETWORK=infra_default
PROJECT3_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PROJECT3_OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000

# Optional: path to a custom .env file (rarely needed)
DOTENV_PATH=
