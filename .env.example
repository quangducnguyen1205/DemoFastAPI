## FastAPI/Backend configuration

# PostgreSQL connection string
# Example for local Docker Compose (service name `db`):
# postgresql://<user>:<password>@db:5432/<database>
DATABASE_URL=postgresql://postgres:postgres@db:5432/userdb

# Root directory for uploaded media (mounted inside the backend container)
MEDIA_ROOT=/app/media

# FAISS index and mapping file paths (default under MEDIA_ROOT)
# Provide full paths if you want to store elsewhere. Otherwise defaults are:
# ${MEDIA_ROOT}/faiss_index.faiss and ${MEDIA_ROOT}/faiss_mapping.pkl
FAISS_INDEX_PATH=
FAISS_MAPPING_PATH=

# Conservative worker defaults for ML-heavy tasks
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Optional: path to a custom .env file (rarely needed)
DOTENV_PATH=
